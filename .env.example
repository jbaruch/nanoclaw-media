# Runtime container variables for the media skills. NanoClaw forwards
# these into main/trusted containers (see README "Required environment").
# Trakt: create an API app at https://trakt.tv/oauth/applications and
# complete the OAuth device-code flow for the access/refresh tokens.
TRAKT_CLIENT_ID=
TRAKT_ACCESS_TOKEN=
TRAKT_REFRESH_TOKEN=
TRAKT_CLIENT_SECRET=
# Optional: env-file path the Trakt token auto-refresh rewrites in place
# to persist rotated tokens. Required for the 401 auto-refresh to run at
# all — without it the script surfaces the 401 rather than burning the
# rotating refresh token it could not persist (see trakt-watch-history.py).
TRAKT_ENV_PATH=
# YouTube Data API v3 key: https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=

# CI reviewer secrets for the jbaruch/coding-policy gh-aw PR review workflows.
# Set as GitHub Actions repository secrets:
#   https://github.com/jbaruch/nanoclaw-media/settings/secrets/actions
# The Codex (OpenAI-family) reviewer reads CODEX_API_KEY or OPENAI_API_KEY
# (CODEX_API_KEY wins when both are set). ANTHROPIC_API_KEY drives the Claude
# reviewer; TESSL_TOKEN authenticates the `tessl install` step for both.
CODEX_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
TESSL_TOKEN=
